rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Single Firestore read shared across all role checks within one request.
    // Caching is per-request, so multiple calls to getRole() only cost one read.
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isEmployer() {
      return isAuthenticated() && getRole() == 'employer';
    }

    function isRecruiter() {
      return isAuthenticated() && getRole() == 'recruiter';
    }

    function isCandidate() {
      return isAuthenticated() && getRole() == 'candidate';
    }

    // ── users ──────────────────────────────────────────────────────────────────
    // Users can only read and write their own document.
    // Admins can read all user documents (for moderation / user management).
    match /users/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ── jobs ───────────────────────────────────────────────────────────────────
    // Any authenticated user can read active jobs.
    // Employers can read their own inactive jobs too.
    // Employers can create jobs they own; can update/delete their own jobs.
    // Candidates can increment applicationsCount only (field-level guard).
    // Admins have full access.
    match /jobs/{jobId} {
      allow read: if isAuthenticated() && (
        resource.data.isActive == true ||
        resource.data.employerUid == request.auth.uid ||
        isAdmin()
      );

      allow create: if isEmployer() &&
        request.resource.data.employerUid == request.auth.uid;

      allow update: if
        // Employer updating their own job
        (isEmployer() && resource.data.employerUid == request.auth.uid) ||
        // Admin
        isAdmin() ||
        // Any authenticated user may increment applicationsCount only
        // (triggered by the candidate smart-apply flow)
        (isAuthenticated() &&
          request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['applicationsCount']));

      allow delete: if
        (isEmployer() && resource.data.employerUid == request.auth.uid) ||
        isAdmin();
    }

    // ── applications ───────────────────────────────────────────────────────────
    // Candidates create applications as themselves.
    // Recruiters can create applications on behalf of candidates.
    // Candidates read their own applications only.
    // Employers read applications for their own jobs.
    // Recruiters can read any application.
    // Admins have full access.
    match /applications/{applicationId} {
      allow create: if
        (isCandidate() && request.resource.data.candidateUid == request.auth.uid) ||
        isRecruiter();

      allow read: if
        isOwner(resource.data.candidateUid) ||
        (isEmployer() && resource.data.employerUid == request.auth.uid) ||
        isRecruiter() ||
        isAdmin();

      allow update: if
        (isEmployer() && resource.data.employerUid == request.auth.uid) ||
        isAdmin();

      allow delete: if isAdmin();
    }

    // ── candidates ─────────────────────────────────────────────────────────────
    // Users read and write their own candidate document only.
    // Employers and recruiters can read candidates (for search / placement).
    // Admins have full access.
    match /candidates/{candidateId} {
      allow read: if
        isOwner(candidateId) ||
        isEmployer() ||
        isRecruiter() ||
        isAdmin();

      allow write: if isOwner(candidateId) || isAdmin();
    }

    // ── employers ──────────────────────────────────────────────────────────────
    // Users read and write their own employer document.
    // Any authenticated user can read employer documents (shown on job detail).
    // Admins have full access.
    match /employers/{employerId} {
      allow read:  if isAuthenticated();
      allow write: if isOwner(employerId) || isAdmin();
    }

    // ── recruiters ─────────────────────────────────────────────────────────────
    // Users read and write their own recruiter document only.
    // Admins can read all recruiter documents.
    match /recruiters/{recruiterId} {
      allow read:  if isOwner(recruiterId) || isAdmin();
      allow write: if isOwner(recruiterId) || isAdmin();
    }

    // ── briefs ─────────────────────────────────────────────────────────────────
    // Recruiters create and manage their own briefs.
    // Employers can read briefs assigned to them (by employerUid).
    // Admins have full access.
    match /briefs/{briefId} {
      allow create: if isRecruiter() &&
        request.resource.data.recruiterUid == request.auth.uid;

      allow read: if
        isOwner(resource.data.recruiterUid) ||
        (isEmployer() && resource.data.employerUid == request.auth.uid) ||
        isAdmin();

      allow update: if isOwner(resource.data.recruiterUid) || isAdmin();
      allow delete: if isOwner(resource.data.recruiterUid) || isAdmin();
    }

    // ── placements ─────────────────────────────────────────────────────────────
    // Recruiters read their own placements.
    // Employers read placements for their company.
    // Only admins can write (placements are managed by the platform).
    match /placements/{placementId} {
      allow read: if
        isOwner(resource.data.recruiterUid) ||
        (isEmployer() && resource.data.employerUid == request.auth.uid) ||
        isAdmin();

      allow write: if isAdmin();
    }

    // ── notifications ──────────────────────────────────────────────────────────
    // Users can read and mark-read their own notifications.
    // Cloud Functions (Admin SDK) bypass these rules automatically.
    // The null-auth create rule covers server-side triggers that do not use
    // the Admin SDK (e.g. emulator tests, callable functions with no impersonation).
    match /notifications/{notificationId} {
      allow read, update: if isOwner(resource.data.recipientUid);
      allow create: if request.auth == null || isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── messages ───────────────────────────────────────────────────────────────
    // Sender and recipient can read messages in a conversation.
    // Users can only create messages where senderUid matches their uid.
    // Admins can update or delete messages (moderation).
    match /messages/{messageId} {
      allow read: if
        isOwner(resource.data.senderUid) ||
        isOwner(resource.data.recipientUid);

      allow create: if
        isAuthenticated() &&
        request.resource.data.senderUid == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // ── certifications ─────────────────────────────────────────────────────────
    // Any authenticated user can read certifications for verification purposes.
    // Users can only write their own certification documents.
    // Admins have full access.
    match /certifications/{certificationId} {
      allow read:  if isAuthenticated();
      allow write: if isOwner(resource.data.uid) || isAdmin();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }
    function isEmployer() {
      return isAuthenticated() && getRole() == 'employer';
    }
    function isRecruiter() {
      return isAuthenticated() && getRole() == 'recruiter';
    }
    function isCandidate() {
      return isAuthenticated() && getRole() == 'candidate';
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if isAuthenticated() && (resource.data.isActive == true || resource.data.employerUid == request.auth.uid || isAdmin());
      allow create: if isEmployer() && request.resource.data.employerUid == request.auth.uid;
      allow update: if (isEmployer() && resource.data.employerUid == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /applications/{applicationId} {
      allow create: if isCandidate() || isRecruiter();
      allow read: if isOwner(resource.data.candidateUid) || isOwner(resource.data.employerUid) || isRecruiter() || isAdmin();
      allow update: if isOwner(resource.data.employerUid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /briefs/{briefId} {
      allow create: if isRecruiter() && request.resource.data.recruiterUid == request.auth.uid;
      allow read: if isOwner(resource.data.recruiterUid) || isOwner(resource.data.employerUid) || isAdmin();
      allow update: if isOwner(resource.data.recruiterUid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /placements/{placementId} {
      allow read: if isOwner(resource.data.recruiterUid) || isAdmin();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update: if isOwner(resource.data.recipientUid);
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isOwner(resource.data.senderUid) || isOwner(resource.data.recipientUid);
      allow create: if isOwner(request.resource.data.senderUid);
      allow update, delete: if isAdmin();
    }
  }
}